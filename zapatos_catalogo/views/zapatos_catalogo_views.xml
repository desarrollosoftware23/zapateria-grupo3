<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_zapatos_catalogo_form" model="ir.ui.view">
        <field name="name">zapatos.zapato.catalogo.form</field>
        <field name="model">zapatos.zapato</field>
        <field name="inherit_id" ref="zapatos.view_zapato_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='talla']" position="after">
                <field name="tipo_zapato"/>
                <field name="temporada_recomendada" readonly="1"/>
            </xpath>
        </field>
    </record>

</odoo>
