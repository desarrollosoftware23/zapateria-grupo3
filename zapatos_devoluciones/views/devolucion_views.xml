<odoo>
    <record id="view_devolucion_list" model="ir.ui.view">
        <field name="name">zapateria.devolucion.list</field>
        <field name="model">zapateria.devolucion</field>
        <field name="arch" type="xml">
            <list decoration-warning="estado == 'pendiente'"
                  decoration-success="estado == 'aprobada'"
                  decoration-danger="estado == 'rechazada'">
                <field name="codigo"/>
                <field name="cliente_id"/>
                <field name="zapato_id"/>
                <field name='venta_id'/>
                <field name="tipo"/>
                <field name="fecha"/>
                <field name="estado" widget="badge"
                       decoration-warning="estado == 'pendiente'"
                       decoration-success="estado == 'aprobada'"
                       decoration-danger="estado == 'rechazada'"/>
            </list>
        </field>
    </record>

    <record id="view_devolucion_form" model="ir.ui.view">
        <field name="name">zapateria.devolucion.form</field>
        <field name="model">zapateria.devolucion</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_aprobar"
                            string="Aprobar"
                            type="object"
                            class="btn-success"
                            invisible="estado != 'pendiente'"/>
                    <button name="action_rechazar"
                            string="Rechazar"
                            type="object"
                            class="btn-danger"
                            invisible="estado != 'pendiente'"/>
                    <button name="action_restablecer"
                            string="Restablecer a Pendiente"
                            type="object"
                            class="btn-secondary"
                            invisible="estado == 'pendiente'"/>

                    <field name="estado" widget="statusbar"
                           statusbar_visible="pendiente,aprobada,rechazada"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="codigo" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Información Principal">
                            <field name="zapato_id"/>
                            <field name='venta_id'/>
                            <field name="cliente_id" readonly="venta_id != False"/>
                            <field name="tipo"/>
                            <field name="fecha"/>
                        </group>

                        <group string="Estado">
                            <field name="estado" readonly="1"/>
                        </group>
                    </group>

                    <group string="Motivo de Devolución">
                        <field name="motivo"
                               nolabel="1"
                               placeholder="Describe el motivo de la devolución (mínimo 10 caracteres)..."/>
                    </group>
                    <group string="Observaciones">
                        <field name="observaciones"
                               nolabel="1"
                               placeholder="Observaciones al aprobar o rechazar..."/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_devolucion_search" model="ir.ui.view">
        <field name="name">zapateria.devolucion.search</field>
        <field name="model">zapateria.devolucion</field>
        <field name="arch" type="xml">
            <search>
                <field name="codigo"/>
                <field name="cliente_id"/>
                <field name='venta_id'/>
                <field name="zapato_id"/>
                <filter string="Pendientes" name="pendientes"
                        domain="[('estado','=','pendiente')]"/>
                <filter string="Aprobadas" name="aprobadas"
                        domain="[('estado','=','aprobada')]"/>
                <filter string="Rechazadas" name="rechazadas"
                        domain="[('estado','=','rechazada')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Zapato" name="by_zapato"
                            context="{'group_by': 'zapato_id'}"/>
                    <filter string="Tipo" name="by_tipo"
                            context="{'group_by': 'tipo'}"/>
                    <filter string="Estado" name="by_estado"
                            context="{'group_by': 'estado'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_devolucion" model="ir.actions.act_window">
        <field name="name">Devoluciones</field>
        <field name="res_model">zapateria.devolucion</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_devolucion_search"/>
    </record>

    <menuitem id="menu_devoluciones" name="Devoluciones" parent="zapatos.menu_zapatos_root" action="action_devolucion" sequence="20"/>
</odoo>